FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/
COPY config/ ./config/

ENV DB_PATH=/data/db_storage
ENV BRAIN_URL=http://localhost:8000/analyze
ENV LIBRARIAN_CONFIG=config/sources.yaml

EXPOSE 8000

CMD ["uvicorn", "src.brain.server:app", "--host", "0.0.0.0", "--port", "8000"]