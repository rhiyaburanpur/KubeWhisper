# ============================================================
# KubeWhisperer — Environment Variable Template
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values below
# 3. NEVER commit .env to version control
# ============================================================


# ------------------------------------------------------------
# REQUIRED: Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here


# ------------------------------------------------------------
# REQUIRED: Shared secret between Go Agent and Python Brain
# Used as the X-API-Key header on POST /analyze requests.
# Set this to any strong random string. Both processes must
# have the same value or requests will be rejected (HTTP 403).
#
# Generate one with:
#   Python:  python -c "import secrets; print(secrets.token_hex(32))"
#   Linux:   openssl rand -hex 32
# ------------------------------------------------------------
KUBEWHISPERER_API_KEY=your_shared_secret_here


# ------------------------------------------------------------
# OPTIONAL: ChromaDB persistence path
# Default: db_storage (relative to project root)
# In production (in-cluster), set this to a mounted volume path
# e.g. /data/db_storage
# ------------------------------------------------------------
DB_PATH=db_storage


# ------------------------------------------------------------
# OPTIONAL: Python Brain URL (used by Go Agent)
# Default: http://localhost:8000/analyze (local development)
# In production, set to the in-cluster Kubernetes Service DNS:
# e.g. http://kubewhisperer-brain.default.svc.cluster.local:8000/analyze
# ------------------------------------------------------------
BRAIN_URL=http://localhost:8000/analyze


# ------------------------------------------------------------
# OPTIONAL: Librarian knowledge sources config file path
# Default: config/sources.yaml
# ------------------------------------------------------------
LIBRARIAN_CONFIG=config/sources.yaml
